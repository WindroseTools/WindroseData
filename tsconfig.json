{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node",
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "data", "languages"]
}